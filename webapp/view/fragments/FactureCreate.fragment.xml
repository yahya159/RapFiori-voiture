<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:f="sap.ui.layout.form">
    <Dialog id="factureCreateDialog" title="Créer facture" contentWidth="36rem" stretch="{device>/system/phone}" class="zyegFormDialog">
        <content>
            <VBox id="factureCreateContent" width="100%" class="zyegDialogBody">
                <f:SimpleForm id="factureCreateForm" editable="true" layout="ResponsiveGridLayout" labelSpanXL="4" labelSpanL="4" labelSpanM="12" labelSpanS="12" adjustLabelSpan="false" emptySpanXL="0" emptySpanL="0" emptySpanM="0" emptySpanS="0" columnsXL="1" columnsL="1" columnsM="1" singleContainerFullSize="false">
                    <f:content>
                        <Label text="Client" required="true" labelFor="factureCreateClientSelect"/>
                        <Select id="factureCreateClientSelect" selectedKey="{ui>/factureCreate/data/Clientid}" items="{ui>/factureCreate/clients}" change="onFactureCreateClientChange" width="100%" forceSelection="false">
                            <items>
                                <core:Item key="{ui>Id}" text="{= ${ui>Prenom} + ' ' + ${ui>Nom} }"/>
                            </items>
                        </Select>

                        <Label text="Nom client" labelFor="factureCreateClientNameInput"/>
                        <Input id="factureCreateClientNameInput" value="{ui>/factureCreate/data/Clientfullname}" editable="false"/>

                        <Label text="Voiture" labelFor="factureCreateVoitureSelect"/>
                        <Select id="factureCreateVoitureSelect" selectedKey="{ui>/factureCreate/data/Voitureid}" items="{ui>/factureCreate/voitures}" width="100%" forceSelection="false">
                            <items>
                                <core:Item key="{ui>Id}" text="{= ${ui>Matricule} + ' - ' + ${ui>Marque} }"/>
                            </items>
                        </Select>

                        <Label text="Montant" required="true" labelFor="factureCreateAmountInput"/>
                        <Input id="factureCreateAmountInput" value="{ui>/factureCreate/data/Amount}" type="Text" valueLiveUpdate="true" liveChange="onFactureCreateFieldLiveChange"/>

                        <Label text="Devise" required="true" labelFor="factureCreateDeviseInput"/>
                        <Input id="factureCreateDeviseInput" value="{ui>/factureCreate/data/Devise}" maxLength="5" valueLiveUpdate="true" liveChange="onFactureCreateFieldLiveChange"/>
                    </f:content>
                </f:SimpleForm>
            </VBox>
        </content>
        <beginButton>
            <Button text="Enregistrer" type="Emphasized" press="onFactureCreateSave"/>
        </beginButton>
        <endButton>
            <Button text="Annuler" press="onFactureCreateCancel"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>
